# ═══════════════════════════════════════════════════════════
# STATIONARY SHOP AI SYSTEM - ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════

# Gemini API Key (Required for OCR)
# Get yours from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Supabase Configuration (Required for Multi-Tenant Database)
# Get yours from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# ═══════════════════════════════════════════════════════════
# SUPABASE DATABASE SETUP INSTRUCTIONS
# ═══════════════════════════════════════════════════════════

# 1. Create a new Supabase project at https://supabase.com
# 2. Go to SQL Editor and run the following SQL:

/*
-- Create inventory table
CREATE TABLE inventory (
    id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
    user_id UUID NOT NULL REFERENCES auth.users(id) ON DELETE CASCADE,
    item_name TEXT NOT NULL,
    stock INTEGER NOT NULL DEFAULT 0,
    avg_daily_sale FLOAT NOT NULL DEFAULT 0,
    reorder INTEGER NOT NULL DEFAULT 0,
    price FLOAT NOT NULL DEFAULT 0,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
    UNIQUE(user_id, item_name)
);

-- Create sales_history table
CREATE TABLE sales_history (
    id UUID DEFAULT gen_random_uuid() PRIMARY KEY,
    user_id UUID NOT NULL REFERENCES auth.users(id) ON DELETE CASCADE,
    date DATE NOT NULL,
    item_name TEXT NOT NULL,
